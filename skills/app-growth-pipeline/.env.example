# Copy to .env and fill in the keys you plan to use.
# Not all are required — only what your chosen stack needs.
# NEVER commit .env to git.

# ==== Track A (zero-cost) — optional for basic use ====
PEXELS_API_KEY=           # https://www.pexels.com/api/ (free)
PIXABAY_API_KEY=          # https://pixabay.com/api/docs/ (free, fallback for Pexels)

# ==== Track B (paid AI video) ====
FAL_API_KEY=              # https://fal.ai/dashboard/keys (pay-as-you-go)

# ==== Caption polish ====
SUBMAGIC_API_KEY=         # https://submagic.co (Business $41/mo)

# ==== TTS ====
HUME_API_KEY=             # https://platform.hume.ai (~$8/mo target usage)
ELEVENLABS_API_KEY=       # https://elevenlabs.io (Pro $99/mo; hero voices only)
# edge-tts and Kokoro need no key

# ==== Transcription ====
DEEPGRAM_API_KEY=         # https://deepgram.com ($200 free signup credit)
OPENAI_API_KEY=           # only if using GPT-4o Transcribe

# ==== Scheduling ====
BLOTATO_API_KEY=          # https://blotato.com (Starter $29/mo)
POSTIZ_URL=               # https://<your-postiz-host>  (self-host fallback)
POSTIZ_API_KEY=

# ==== Research / scraping ====
APIFY_TOKEN=              # https://console.apify.com (Starter $49/mo)
FIRECRAWL_API_KEY=        # https://firecrawl.dev (Hobby $16/mo)

# ==== Analytics ====
TIKTOK_BUSINESS_TOKEN=    # apply via TikTok for Developers
META_GRAPH_TOKEN=         # via Meta for Developers
YOUTUBE_API_KEY=          # Google Cloud console
SINGULAR_API_KEY=         # https://www.singular.net (free MMP tier)

# ==== LLM ====
ANTHROPIC_API_KEY=        # for script generation outside Claude Code sessions
                          # (inside Claude Code you don't need this)

# ==== Misc ====
# Override the default ~/.claude/skills/app-growth-pipeline/ location if you
# installed the skill elsewhere. Usually unnecessary.
# APP_GROWTH_SKILL_ROOT=
